# Enable Mock Service Worker for local development
VITE_ENABLE_MSW=true

# API Base URL (used when MSW is disabled)
VITE_API_BASE_URL=https://api.ops.nedu.vn

# App environment
VITE_APP_ENV=development

# Google OAuth Client ID (for production)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Feature flags
VITE_ENABLE_PERSONAL_PROFILE=true
VITE_ENABLE_CO_DEAL=true
VITE_ENABLE_KPI_PANEL=true
